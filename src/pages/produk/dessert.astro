---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProductGrid from "@components/produk/ProductGrid";
---

<BaseLayout
  title="Dessert & Snack Frozen | IcePack Foods"
  description="Camilan manis dan dessert beku untuk akhir pekan."
>
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-medium tracking-tight mb-3 text-ink">Dessert & Snack.</h1>
      <p class="text-body text-lg mb-10">Camilan manis dan dessert beku untuk akhir pekan.</p>

      <ProductGrid client:load initialCategory="Dessert & Snack" />
    </div>
  </section>
</BaseLayout>
