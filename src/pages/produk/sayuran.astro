---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProductGrid from "@components/produk/ProductGrid";
---

<BaseLayout
  title="Sayuran Frozen Frozen | IcePack Foods"
  description="Sayuran beku praktis, tidak perlu potong, langsung masak."
>
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-medium tracking-tight mb-3 text-ink">Sayuran Frozen.</h1>
      <p class="text-body text-lg mb-10">Sayuran beku praktis, tidak perlu potong, langsung masak.</p>

      <ProductGrid client:load initialCategory="Sayuran Frozen" />
    </div>
  </section>
</BaseLayout>
