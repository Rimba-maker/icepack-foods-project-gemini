---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProductGrid from "@components/produk/ProductGrid";
---

<BaseLayout
  title="Seafood Frozen Frozen | IcePack Foods"
  description="Seafood segar yang dibekukan cepat, nutrisi terjaga."
>
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-6">
      <h1 class="text-3xl md:text-4xl font-medium tracking-tight mb-3 text-ink">Seafood Frozen.</h1>
      <p class="text-body text-lg mb-10">Seafood segar yang dibekukan cepat, nutrisi terjaga.</p>

      <ProductGrid client:load initialCategory="Seafood Frozen" />
    </div>
  </section>
</BaseLayout>
