---
import BaseLayout from "@layouts/BaseLayout.astro";
import B2BForm from "@components/forms/B2BForm";
import CatalogDownload from "@components/forms/CatalogDownload";
import { 
  BowlLine, ComputerLine, Building3Line, ForkSpoonLine, SchoolLine, StoreLine,
  CoinLine, CalendarLine, BillLine, User1Line, Box3Line, Refresh1Line 
} from "@mingcute/react";
---

<BaseLayout
  title="Supplier Frozen Food untuk Restoran & Hotel | IcePack Foods"
  description="Mitra frozen food untuk restoran, cloud kitchen, hotel, catering, dan kantin. Harga grosir, cold chain terjaga, pengiriman terjadwal."
>
  <!-- S1: Hero -->
  <section class="bg-surface-dark text-white py-20 lg:py-32 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="max-w-3xl">
        <p class="eyebrow text-b2b-light text-xs mb-4">B2B SUPPLIER PROGRAM</p>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight leading-[1.1] mb-6">
          Partner Frozen Food Terpercaya untuk Bisnis F&B Anda.
        </h1>
        <p class="text-white/70 text-lg md:text-xl mb-10">
          Harga grosir, pengiriman terjadwal, cold chain terjaga, dan support account manager dedicated. Bergabunglah dengan 200+ mitra bisnis yang sudah percaya IcePack.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#daftar" class="px-8 py-4 bg-b2b text-white font-semibold rounded-full text-lg hover:bg-b2b-hover transition-colors shadow-lg shadow-b2b/20 text-center flex items-center justify-center">
            Daftar Jadi Mitra
          </a>
          <CatalogDownload client:idle />
        </div>
      </div>
    </div>
  </section>

  <!-- Rest of supplier page remains the same... -->
  <!-- S2: Who Is This For -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-3">Untuk Siapa Program Ini?</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {[
          { Icon: BowlLine, title: "Restoran & Warteg", desc: "Bahan baku konsisten, harga stabil" },
          { Icon: ComputerLine, title: "Cloud Kitchen", desc: "Volume harian, pengiriman terjadwal" },
          { Icon: Building3Line, title: "Hotel & Resort", desc: "Breakfast buffet, banquet supply" },
          { Icon: ForkSpoonLine, title: "Catering & EO", desc: "Bulk order per event" },
          { Icon: SchoolLine, title: "Kantin Sekolah & Pabrik", desc: "Supply rutin bulanan" },
          { Icon: StoreLine, title: "Minimarket & Reseller", desc: "Ready to resell packaging" },
        ].map(({Icon, title, desc}) => (
          <div class="bg-canvas-soft rounded-2xl p-6 border border-hairline-soft hover:-translate-y-1 transition-transform">
            <div class="mb-4 text-primary">
              <Icon className="w-10 h-10" />
            </div>
            <h3 class="font-medium text-lg mb-2 text-ink">{title}</h3>
            <p class="text-body text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- S3: B2B Benefits -->
  <section class="bg-canvas-soft py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-14">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-3">Keuntungan Jadi Mitra IcePack.</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { Icon: CoinLine, title: "Harga Grosir Kompetitif", desc: "Hemat 20-35% dari harga eceran. Semakin besar volume, semakin baik harganya." },
          { Icon: CalendarLine, title: "Pengiriman Terjadwal", desc: "Set jadwal pengiriman per hari, per minggu, atau per bulan. Kami datang tepat waktu — tanpa kamu perlu ingatkan." },
          { Icon: BillLine, title: "Invoice & Faktur Pajak", desc: "Semua transaksi dilengkapi invoice resmi dan faktur pajak (PKP). Cocok untuk pelaporan keuangan bisnis & reimbursement." },
          { Icon: User1Line, title: "Account Manager Dedicated", desc: "Satu PIC khusus untuk bisnis kamu. WA langsung, respon cepat, bukan bot." },
          { Icon: Box3Line, title: "Minimum Order Fleksibel", desc: "Mulai dari 10 kg untuk trial. Tidak perlu langsung volume besar untuk mulai." },
          { Icon: Refresh1Line, title: "Konsistensi Produk", desc: "Setiap batch produk dikontrol kualitasnya. Tidak ada perbedaan rasa atau tekstur antar pengiriman." },
        ].map(({Icon, title, desc}) => (
          <div class="bg-canvas rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="mb-4 text-b2b">
              <Icon className="w-10 h-10" />
            </div>
            <h3 class="font-medium text-lg mb-2 text-ink">{title}</h3>
            <p class="text-body text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- S4: Pricing Structure -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-medium tracking-tight mb-3">Struktur Harga Grosir.</h2>
        <p class="text-body text-lg">Harga berdasarkan volume. Semakin besar, semakin hemat.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { volume: "10–50 kg", discount: "20% off", support: "Standard (WA)", bg: "bg-canvas", border: "border-hairline-strong" },
          { volume: "50–200 kg", discount: "25% off", support: "Dedicated WA + monthly visit", bg: "bg-canvas", border: "border-hairline-strong" },
          { volume: "200–500 kg", discount: "30% off", support: "Account Manager", bg: "bg-b2b-soft", border: "border-b2b", featured: true },
          { volume: "500 kg+", discount: "35% off", support: "Senior Account Manager + priority", bg: "bg-surface-dark", border: "border-surface-dark", text: "text-white" },
        ].map((tier) => (
          <div class={`rounded-[24px] p-8 border-2 ${tier.border} ${tier.bg} ${tier.text || "text-ink"} relative`}>
            {tier.featured && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-b2b text-white text-xs font-semibold rounded-full whitespace-nowrap">
                Paling Diminati
              </div>
            )}
            <p class={`text-sm mb-2 ${tier.text ? "text-white/70" : "text-body"}`}>Volume per Bulan</p>
            <h3 class="text-2xl font-medium mb-6">{tier.volume}</h3>
            
            <div class={`text-4xl font-semibold mb-6 ${tier.featured ? "text-b2b" : tier.text ? "text-white" : "text-primary"}`}>
              {tier.discount}
            </div>
            
            <hr class={`mb-6 ${tier.text ? "border-white/20" : "border-hairline"}`} />
            
            <div class="flex items-start gap-3 mb-8">
              <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <p class="text-sm font-medium">{tier.support}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center text-sm text-body-mid mt-8 italic">*Harga final setelah konsultasi dan survey kebutuhan.</p>
    </div>
  </section>

  <!-- Form Pendaftaran -->
  <section id="daftar" class="py-20 lg:py-28 bg-canvas-soft border-t border-hairline-soft">
    <div class="max-w-3xl mx-auto px-6">
      <B2BForm client:visible />
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WholesaleStore",
    "name": "IcePack Foods B2B",
    "image": "https://icepackfoods.id/og-default.jpg",
    "description": "Supplier frozen food untuk restoran, cloud kitchen, hotel, dan catering.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "ID"
    }
  })} />
</BaseLayout>
