---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import { TimeLine, FireLine, ForkSpoonLine } from "@mingcute/react";
export async function getStaticPaths() {
  const resepEntries = await getCollection("resep");
  return resepEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={`${entry.data.title} | Resep IcePack Foods`}
  description={entry.data.description}
>
  <article class="py-20 lg:py-28">
    <div class="max-w-3xl mx-auto px-6">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-body-mid">
        <a href="/" class="hover:text-primary transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/resep/" class="hover:text-primary transition-colors">Resep</a>
        <span class="mx-2">/</span>
        <span class="text-ink">{entry.data.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-medium tracking-tight mb-6">
          {entry.data.title}
        </h1>
        <p class="text-xl text-body mb-8">
          {entry.data.description}
        </p>

        <!-- Meta -->
        <div class="flex flex-wrap justify-center gap-6 text-sm border-y border-hairline-soft py-4">
          <div class="flex items-center gap-2">
            <TimeLine className="w-6 h-6 text-primary" />
            <div>
              <span class="block text-body-mid text-xs uppercase tracking-wider">Prep</span>
              <span class="font-medium text-ink">{entry.data.prepTime}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <FireLine className="w-6 h-6 text-primary" />
            <div>
              <span class="block text-body-mid text-xs uppercase tracking-wider">Cook</span>
              <span class="font-medium text-ink">{entry.data.cookTime}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <ForkSpoonLine className="w-6 h-6 text-primary" />
            <div>
              <span class="block text-body-mid text-xs uppercase tracking-wider">Porsi</span>
              <span class="font-medium text-ink">{entry.data.servings} Porsi</span>
            </div>
          </div>
        </div>
      </header>

      <!-- Highlight Product -->
      <div class={`${entry.data.categoryColor} ${entry.data.categoryText} rounded-2xl p-6 mb-12 flex items-center justify-between border border-hairline`}>
        <div>
          <p class="eyebrow opacity-80 mb-1">PRODUK UTAMA</p>
          <p class="text-lg font-medium">{entry.data.mainIngredient}</p>
        </div>
        <a href="/produk/" class="px-5 py-2.5 bg-canvas rounded-full text-sm font-semibold border border-hairline hover:bg-ink hover:text-white hover:border-ink transition-colors">
          Beli Sekarang
        </a>
      </div>

      <!-- Markdown Content -->
      <div class="prose prose-lg prose-headings:font-medium prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-2xl max-w-none text-body">
        <Content />
      </div>
    </div>
  </article>

  <!-- Recipe Schema JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org/",
    "@type": "Recipe",
    "name": entry.data.title,
    "description": entry.data.description,
    "prepTime": `PT${entry.data.prepTime.replace(/\D/g, '')}M`,
    "cookTime": `PT${entry.data.cookTime.replace(/\D/g, '')}M`,
    "recipeYield": entry.data.servings,
    "recipeIngredient": [entry.data.mainIngredient]
  })} />
</BaseLayout>
