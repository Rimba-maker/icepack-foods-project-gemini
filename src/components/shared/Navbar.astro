---
/**
 * IcePack Foods — Navbar
 * Design: Mastercard floating pill nav + Zapier warm canvas + PRD dual CTA
 *
 * - Floating pill shape (Mastercard: 999px radius, soft shadow, top margin)
 * - Warm canvas background (Zapier: #fffefb)
 * - Dual CTA: B2C orange "Order Sekarang" + B2B navy "Jadi Mitra" (PRD)
 * - Dropdown produk with 10 categories
 */

const navLinks = [
  {
    label: "Produk",
    href: "/produk/",
    dropdown: [
      { label: "Dimsum & Siomay", href: "/produk/dimsum/" },
      { label: "Bakso & Pentol", href: "/produk/bakso/" },
      { label: "Nugget & Olahan Ayam", href: "/produk/nugget/" },
      { label: "Sosis & Hotdog", href: "/produk/sosis/" },
      { label: "Seafood Frozen", href: "/produk/seafood/" },
      { label: "Sayuran Frozen", href: "/produk/sayuran/" },
      { label: "Ready to Eat", href: "/produk/ready-to-eat/" },
      { label: "Healthy Range", href: "/produk/healthy/" },
      { label: "Dessert & Snack", href: "/produk/dessert/" },
      { label: "Western Frozen", href: "/produk/western/" },
    ],
  },
  { label: "Supplier/B2B", href: "/supplier/" },
  { label: "Reseller", href: "/reseller/" },
  { label: "Resep", href: "/resep/" },
  { label: "Tentang", href: "/tentang/" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 px-4 pt-4">
  <nav
    class="mx-auto max-w-7xl bg-canvas/95 backdrop-blur-md rounded-[999px] shadow-nav px-6 py-3 flex items-center justify-between"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0">
      <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
        <span class="text-on-primary font-bold text-sm">❄️</span>
      </div>
      <span class="font-semibold text-lg tracking-tight text-ink">
        IcePack <span class="text-primary">Foods</span>
      </span>
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <div class="relative group">
          <a
            href={link.href}
            class:list={[
              "px-4 py-2 rounded-full text-sm font-medium transition-colors",
              currentPath.startsWith(link.href)
                ? "text-primary bg-primary-soft"
                : "text-ink hover:text-primary hover:bg-primary-soft/50",
            ]}
          >
            {link.label}
            {link.dropdown && (
              <svg class="inline-block w-3.5 h-3.5 ml-1 -mr-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            )}
          </a>

          {/* Dropdown */}
          {link.dropdown && (
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
              <div class="bg-canvas rounded-2xl shadow-lg border border-hairline-soft p-2 min-w-[220px]">
                {link.dropdown.map((sub) => (
                  <a
                    href={sub.href}
                    class="block px-4 py-2.5 text-sm text-body rounded-xl hover:bg-canvas-soft hover:text-ink transition-colors"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Dual CTA (PRD: two different colored CTAs) -->
    <div class="hidden lg:flex items-center gap-3">
      <!-- B2C CTA: Orange -->
      <a
        href="https://wa.me/628xxxxxxxxx?text=Halo%20IcePack%20saya%20mau%20order"
        class="px-5 py-2.5 bg-primary text-on-primary text-sm font-semibold rounded-full hover:bg-primary-hover transition-colors"
      >
        Order Sekarang
      </a>
      <!-- B2B CTA: Navy -->
      <a
        href="/supplier/"
        class="px-5 py-2.5 bg-b2b text-white text-sm font-semibold rounded-full hover:bg-b2b-hover transition-colors"
      >
        Jadi Mitra
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 rounded-full hover:bg-canvas-soft transition-colors"
      aria-label="Menu"
    >
      <svg class="w-6 h-6 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-canvas z-[60] hidden flex-col pt-20 px-6 pb-8 lg:hidden"
  >
    <button
      id="mobile-menu-close"
      class="absolute top-6 right-6 p-2 rounded-full hover:bg-canvas-soft"
      aria-label="Tutup menu"
    >
      <svg class="w-6 h-6 text-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div class="flex flex-col gap-2">
      {navLinks.map((link) => (
        <>
          <a
            href={link.href}
            class="px-4 py-3 text-lg font-medium text-ink rounded-2xl hover:bg-canvas-soft"
          >
            {link.label}
          </a>
          {link.dropdown?.map((sub) => (
            <a
              href={sub.href}
              class="px-8 py-2 text-sm text-body rounded-xl hover:bg-canvas-soft"
            >
              {sub.label}
            </a>
          ))}
        </>
      ))}
    </div>

    <div class="mt-auto flex flex-col gap-3 pt-6">
      <a
        href="https://wa.me/628xxxxxxxxx"
        class="w-full py-3 bg-primary text-on-primary text-center font-semibold rounded-full"
      >
        Order Sekarang
      </a>
      <a
        href="/supplier/"
        class="w-full py-3 bg-b2b text-white text-center font-semibold rounded-full"
      >
        Jadi Mitra
      </a>
    </div>
  </div>
</header>

<!-- Spacer for fixed nav -->
<div class="h-20"></div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const close = document.getElementById("mobile-menu-close");

  btn?.addEventListener("click", () => {
    menu?.classList.remove("hidden");
    menu?.classList.add("flex");
    document.body.style.overflow = "hidden";
  });

  close?.addEventListener("click", () => {
    menu?.classList.add("hidden");
    menu?.classList.remove("flex");
    document.body.style.overflow = "";
  });
</script>
